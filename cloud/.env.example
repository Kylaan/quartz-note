# =========================================================
# notes-site / 云机侧（拉取+伺服）配置 —— 复制为 .env 再填写
#   cp .env.example .env
# =========================================================

# ----- NAS S3（用于从 AList 拉构建产物，环境变量式配置，远端名 = NAS）-----
RCLONE_CONFIG_NAS_TYPE=s3
RCLONE_CONFIG_NAS_PROVIDER=Other
RCLONE_CONFIG_NAS_ACCESS_KEY_ID=your-access-key
RCLONE_CONFIG_NAS_SECRET_ACCESS_KEY=your-secret-key
RCLONE_CONFIG_NAS_ENDPOINT=http://100.68.43.37:5246
RCLONE_CONFIG_NAS_REGION=us-east-1
RCLONE_CONFIG_NAS_FORCE_PATH_STYLE=true

# 构建产物所在的远端路径（NAS 上 AList 把产物目录暴露成的存储/路径）
SITE_REMOTE=NAS:site

# ----- 错峰拉取参数 -----
# 每轮检查间隔（秒）
PULL_INTERVAL=300
# 宿主机 1 分钟负载闸门：高于此值就退避（2 核机建议 1.5）
LOAD_MAX=1.5
# rclone 带宽上限，温柔拉取（0 为不限）
BWLIMIT=2M
