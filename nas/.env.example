# =========================================================
# notes-site / NAS 侧（构建）配置 —— 复制为 .env 再填写
#   cp .env.example .env
# =========================================================

# ----- NAS S3（rclone 远端，环境变量式配置，远端名 = NAS）-----
RCLONE_CONFIG_NAS_TYPE=s3
RCLONE_CONFIG_NAS_PROVIDER=Other
RCLONE_CONFIG_NAS_ACCESS_KEY_ID=your-access-key
RCLONE_CONFIG_NAS_SECRET_ACCESS_KEY=your-secret-key
RCLONE_CONFIG_NAS_ENDPOINT=http://100.68.43.37:5246
RCLONE_CONFIG_NAS_REGION=us-east-1
RCLONE_CONFIG_NAS_FORCE_PATH_STYLE=true

# 拉取笔记的远端路径：桶名（可加前缀）。白名单在 filter-public.txt 里。
RCLONE_REMOTE=NAS:obsidian

# ----- 站点 -----
SITE_TITLE=我的笔记
# 你对外的域名（反代后的最终访问域名），用于站内绝对链接/sitemap/RSS
BASE_URL=notes.example.com
# 同步+构建间隔（秒）
SYNC_INTERVAL=600
# 构建并发线程数：NAS 内存足留空=按核数跑满最快；偏小设 1 砍内存峰值
BUILD_CONCURRENCY=
